rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - role: string (required, 'admin' or 'creator')
    //   - displayName: string (optional)
    //
    // Collection: withdrawals
    // Document ID: withdrawalId
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required, positive)
    //   - method: string (required)
    //   - details: string (optional)
    //   - status: string (required, 'pending', 'approved', 'rejected', 'paid')
    //   - date: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "hosenmdjakir629@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'creator'];
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'amount', 'method', 'status', 'date']) &&
             data.userId is string &&
             data.amount is number && data.amount > 0 &&
             data.method is string &&
             data.status in ['pending', 'approved', 'rejected', 'paid'] &&
             data.date is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isAdmin() && isValidWithdrawal(request.resource.data);
    }
    
    match /creators/{creatorId} {
      allow read: if isAuthenticated();
      allow update: if isAdmin();
    }
    
    match /applications/{applicationId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
    }
    
    match /earnings/{earningId} {
      allow read: if isAuthenticated() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }
    
    match /content_id_assets/{assetId} {
      allow read: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
    }

    match /claims/{claimId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.creatorId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /email_templates/{templateId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /invites/{inviteId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /platform_settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
