{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the CMS, typically an admin.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "manager", "creator"], "description": "The user's role." },
        "name": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." }
      },
      "required": ["uid", "email", "role"]
    },
    "Channel": {
      "title": "Channel",
      "description": "A YouTube channel linked to the MCN.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique channel ID." },
        "name": { "type": "string", "description": "Channel name." },
        "youtubeChannelId": { "type": "string", "description": "YouTube Channel ID." },
        "type": { "type": "string", "enum": ["Affiliate", "Owned"], "description": "Channel type." },
        "status": { "type": "string", "enum": ["Pending", "Active", "Released"], "description": "Channel status." },
        "ownerId": { "type": "string", "description": "UID of the creator/user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["id", "name", "youtubeChannelId", "type", "status", "createdAt"]
    },
    "Creator": {
      "title": "Creator",
      "description": "A creator managed by the MCN.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Creator's full name." },
        "email": { "type": "string", "format": "email", "description": "Creator's email address." },
        "phone": { "type": "string", "description": "Creator's phone or WhatsApp number." },
        "channel": { "type": "string", "description": "Link to the creator's channel." },
        "subs": { "type": "string", "description": "Subscriber count as a string." },
        "channelName": { "type": "string", "description": "YouTube channel name." },
        "subscribers": { "type": "number", "description": "Subscriber count as a number." },
        "totalViews": { "type": "number", "description": "Total views." },
        "videoCount": { "type": "number", "description": "Total number of videos." },
        "revenue": { "type": "number", "description": "Monthly revenue." },
        "niche": { "type": "string", "description": "Content niche." },
        "message": { "type": "string", "description": "Creator's message or goal." },
        "avatarUrl": { "type": "string", "format": "uri", "description": "Avatar image URL." },
        "status": { "type": "string", "enum": ["Active", "Pending", "Suspended", "Inactive", "Processing"], "description": "Creator status." },
        "trend": { "type": "string", "enum": ["up", "down", "flat"], "description": "Performance trend." },
        "uid": { "type": "string", "description": "The UID of the creator's logged-in account." },
        "linkedChannelHandle": { "type": "string", "description": "YouTube handle (@handle)." },
        "youtubeChannelId": { "type": "string", "description": "YouTube Channel ID (UC...)." },
        "isVerified": { "type": "boolean", "description": "Whether the channel is verified by the MCN." },
        "zipUrl": { "type": "string", "format": "uri", "description": "URL to the uploaded ZIP file." },
        "adminNotes": { "type": "string", "description": "Internal administrative notes about the creator." },
        "payoutOption": { "type": "string", "enum": ["Bank Transfer", "PayPal", "Bkash", "Nagad"], "description": "Preferred payout method." },
        "payoutDetails": { "type": "string", "description": "Account details for the payout method." },
        "videos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "uploadedAt": { "type": "string", "format": "date-time" },
              "size": { "type": "number" },
              "status": { "type": "string", "enum": ["Processing", "Ready", "Failed"] }
            }
          },
          "description": "List of uploaded video files."
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "createdBy": { "type": "string", "description": "UID of the user who added this creator." },
        "contract": {
          "type": "object",
          "properties": {
            "startDate": { "type": "string", "format": "date" },
            "endDate": { "type": "string", "format": "date" },
            "revenueSplit": { "type": "number" }
          }
        },
        "kyc": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] },
            "documentUrl": { "type": "string", "format": "uri" }
          }
        },
        "tier": { "type": "string", "enum": ["Silver", "Gold", "VIP"] }
      },
      "required": ["name", "status", "trend"]
    },
    "Application": {
      "title": "Application",
      "description": "A creator application for joining the MCN.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Applicant's full name." },
        "email": { "type": "string", "format": "email", "description": "Applicant's email address." },
        "channelName": { "type": "string", "description": "YouTube channel name." },
        "channelUrl": { "type": "string", "description": "Link to the YouTube channel." },
        "subscribers": { "type": "number", "description": "Subscriber count." },
        "niche": { "type": "string", "description": "Content niche." },
        "message": { "type": "string", "description": "Applicant's message." },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected", "More Info Needed"], "description": "Application status." },
        "adminNotes": { "type": "string", "description": "Notes from the admin review." },
        "reviewedAt": { "type": "string", "format": "date-time", "description": "When the application was reviewed." },
        "reviewedBy": { "type": "string", "description": "UID of the admin who reviewed it." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the application was submitted." }
      },
      "required": ["name", "email", "channelName", "status", "createdAt"]
    },
    "Log": {
      "title": "Log",
      "description": "System activity log.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of the event." },
        "action": { "type": "string", "description": "The action performed." },
        "details": { "type": "string", "description": "Details of the action." },
        "user": { "type": "string", "description": "The user who performed the action." },
        "userId": { "type": "string", "description": "The UID of the user who performed the action." }
      },
      "required": ["timestamp", "action", "details", "user", "userId"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Daily analytics data.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "Date string (e.g., 'Oct 12')." },
        "views": { "type": "number", "description": "Daily views." },
        "revenue": { "type": "number", "description": "Daily revenue." },
        "subs": { "type": "number", "description": "Daily new subscribers." },
        "timestamp": { "type": "string", "format": "date-time", "description": "ISO timestamp for sorting." }
      },
      "required": ["date", "views", "revenue", "subs", "timestamp"]
    },
    "Earnings": {
      "title": "Earnings",
      "description": "Monthly earnings record for a creator with split engine details.",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string", "description": "UID of the creator." },
        "channelId": { "type": "string", "description": "ID of the channel." },
        "month": { "type": "string", "description": "Month string (e.g., '2024-03')." },
        "totalRevenue": { "type": "number", "description": "Total revenue before split." },
        "creatorShare": { "type": "number", "description": "Share allocated to the creator." },
        "mcnShare": { "type": "number", "description": "Share allocated to the MCN." },
        "bonusPool": { "type": "number", "description": "Share allocated to the bonus pool." },
        "creatorPercentage": { "type": "number", "description": "Percentage for creator." },
        "mcnPercentage": { "type": "number", "description": "Percentage for MCN." },
        "bonusPercentage": { "type": "number", "description": "Percentage for bonus pool." },
        "status": { "type": "string", "enum": ["Accrued", "Ready", "Paid"], "description": "Payment status." }
      },
      "required": ["creatorId", "totalRevenue", "creatorShare", "mcnShare", "bonusPool", "status"]
    },
    "Payout": {
      "title": "Payout",
      "description": "A withdrawal request or payment record.",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string", "description": "UID of the creator." },
        "amount": { "type": "number", "description": "Amount in BDT." },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Paid", "Rejected"], "description": "Status of the payout." },
        "method": { "type": "string", "description": "Payment method used." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of request." },
        "processedAt": { "type": "string", "format": "date-time", "description": "Time of completion." },
        "reference": { "type": "string", "description": "Transaction reference ID." }
      },
      "required": ["creatorId", "amount", "status", "method", "timestamp"]
    },
    "Claim": {
      "title": "Claim",
      "description": "A copyright claim on a creator's video.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique claim ID." },
        "contentId": { "type": "string", "description": "YouTube Content ID." },
        "title": { "type": "string", "description": "Video title." },
        "claimant": { "type": "string", "description": "Name of the claimant." },
        "matchType": { "type": "string", "description": "Type of match (Visual, Audio, etc.)." },
        "status": { "type": "string", "enum": ["Active", "Disputed", "Released"], "description": "Status of the claim." },
        "date": { "type": "string", "description": "Date of detection." },
        "deadline": { "type": "string", "description": "Deadline for response." },
        "notes": { "type": "string", "description": "Additional notes." },
        "statusColor": { "type": "string", "description": "UI color class." },
        "notified": { "type": "boolean", "description": "Whether the creator has been notified." },
        "creatorId": { "type": "string", "description": "UID of the creator who owns the video." }
      },
      "required": ["id", "title", "claimant", "status", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Admin notification.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Creator name." },
        "email": { "type": "string", "format": "email", "description": "Creator email." },
        "channel": { "type": "string", "description": "Channel link." },
        "subs": { "type": "string", "description": "Subscriber count string." },
        "channelName": { "type": "string", "description": "Channel name." },
        "subscribers": { "type": "number", "description": "Subscriber count." },
        "niche": { "type": "string", "description": "Content niche." },
        "message": { "type": "string", "description": "Creator message." },
        "formattedMessage": { "type": "string", "description": "Requested template formatted message." },
        "zipUrl": { "type": "string", "format": "uri", "description": "URL to the uploaded ZIP file." },
        "status": { "type": "string", "enum": ["unread", "read"], "description": "Notification status." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of notification." }
      },
      "required": ["name", "status", "timestamp"]
    },
    "VideoAnalytics": {
      "title": "VideoAnalytics",
      "description": "Analytics data for a specific video.",
      "type": "object",
      "properties": {
        "videoId": { "type": "string", "description": "The ID of the video." },
        "creatorId": { "type": "string", "description": "The UID of the creator who owns the video." },
        "views": { "type": "number", "description": "Total views for the video." },
        "watchTime": { "type": "number", "description": "Total watch time in hours." },
        "likes": { "type": "number", "description": "Total likes for the video." },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last time the analytics were updated." }
      },
      "required": ["videoId", "creatorId", "views", "watchTime", "likes", "lastUpdated"]
    },
    "ContentIdAsset": {
      "title": "ContentIdAsset",
      "description": "An original asset owned by the MCN for Content ID matching.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Asset title." },
        "type": { "type": "string", "enum": ["Audio", "Video", "Audiovisual"], "description": "Asset type." },
        "artist": { "type": "string", "description": "Artist or primary owner." },
        "isrc": { "type": "string", "description": "ISRC or custom ID." },
        "policy": { "type": "string", "enum": ["Monetize", "Block", "Track"], "description": "Match policy." },
        "status": { "type": "string", "enum": ["Active", "Inactive"], "description": "Asset status." },
        "ownerUid": { "type": "string", "description": "UID of the user who added the asset." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["title", "type", "artist", "policy", "status", "ownerUid", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/creators/{creatorId}": {
      "schema": { "$ref": "#/entities/Creator" },
      "description": "Stores managed creators."
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "Stores system activity logs."
    },
    "/analytics/{analyticsId}": {
      "schema": { "$ref": "#/entities/Analytics" },
      "description": "Stores daily analytics data."
    },
    "/earnings/{earningsId}": {
      "schema": { "$ref": "#/entities/Earnings" },
      "description": "Stores monthly earnings records."
    },
    "/payouts/{payoutId}": {
      "schema": { "$ref": "#/entities/Payout" },
      "description": "Stores payout requests and history."
    },
    "/claims/{claimId}": {
      "schema": { "$ref": "#/entities/Claim" },
      "description": "Stores copyright claims detected on creator videos."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Stores admin notifications."
    },
    "/applications/{applicationId}": {
      "schema": { "$ref": "#/entities/Application" },
      "description": "Stores creator applications."
    },
    "/channels/{channelId}": {
      "schema": { "$ref": "#/entities/Channel" },
      "description": "Stores linked YouTube channels."
    },
    "/videoAnalytics/{analyticsId}": {
      "schema": { "$ref": "#/entities/VideoAnalytics" },
      "description": "Stores analytics data for uploaded videos."
    },
    "/content_id_assets/{assetId}": {
      "schema": { "$ref": "#/entities/ContentIdAsset" },
      "description": "Stores original assets for Content ID matching."
    }
  }
}
